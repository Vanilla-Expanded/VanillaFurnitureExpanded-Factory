<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<PipeSystem.ProcessDef>
		<defName>VFEFactory_MakeCannedMeat</defName>
		<label>Make canned meat</label>
		<labelOverride>Make canned meat</labelOverride>
		<description>Safely store raw meat in a steel can. Canning extends its shelf life almost indefinitely. 20 cans will be produced per every nutrition consumed, so 20 meat plus one steel will output 20 cans.</description>
		<priorityInBillList>1</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<useIngredients>true</useIngredients>
		<autoInputSlots>
			<li>(-2,0,2)</li>
			<li>(2,0,2)</li>
		</autoInputSlots>
		<ticks>3600</ticks>
		<ingredients>
			<li>
				<thing>Steel</thing>
				<countNeeded>1</countNeeded>
			</li>
			<li>
				<thingCategory>MeatRaw</thingCategory>
				<countNeeded>20</countNeeded>			
			</li>
		</ingredients>
		<results>
			<li>
				<thing>VCE_CannedMeat</thing>
				<count>20</count>
				<workerClass>VanillaFurnitureExpandedFactory.ResultWorker_TotalNutrition_Cans</workerClass>
				<outputStringOverride>VFEFactory_Cans</outputStringOverride>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedMachiningSustainer</sustainerDef>
		<effecterWhenWorking>true</effecterWhenWorking>
		<effecterDef>VFEFactory_Default</effecterDef>
	</PipeSystem.ProcessDef>
