<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Chemfuel Expanded</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationAdd">
					<xpath>Defs/PipeSystem.ProcessDef[defName="VFEFactory_SynthesizeNeutroamine"]</xpath>
					<value>
						<considerBuildingCompResource>true</considerBuildingCompResource>
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/PipeSystem.ProcessDef[defName="VFEFactory_MakeHighExplosiveShells"]</xpath>
					<value>
						<considerBuildingCompResource>true</considerBuildingCompResource>
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/PipeSystem.ProcessDef[defName="VFEFactory_MakeIncendiaryShells"]</xpath>
					<value>
						<considerBuildingCompResource>true</considerBuildingCompResource>
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/PipeSystem.ProcessDef[defName="VFEFactory_AlloyPlasteel"]</xpath>
					<value>
						<considerBuildingCompResource>true</considerBuildingCompResource>
					</value>
				</li>
				<li Class="PatchOperationFindMod">
					<mods>
						<li>Biotech</li>
					</mods>
					<match Class="PatchOperationAdd">
						<xpath>Defs/PipeSystem.ProcessDef[defName="VFEFactory_MakeToxShells"]</xpath>
						<value>
							<considerBuildingCompResource>true</considerBuildingCompResource>
						</value>
					</match>
				</li>
				<li Class="PatchOperationFindMod">
					<mods>
						<li>Vanilla Factions Expanded - Deserters</li>
					</mods>
					<match Class="PatchOperationAdd">
						<xpath>Defs/PipeSystem.ProcessDef[defName="VFEFactory_MakeArmorPiercingShells"]</xpath>
						<value>
							<considerBuildingCompResource>true</considerBuildingCompResource>
						</value>
					</match>
				</li>
				<li Class="PatchOperationFindMod">
					<mods>
						<li>Vanilla Factions Expanded - Deserters</li>
					</mods>
					<match Class="PatchOperationAdd">
						<xpath>Defs/PipeSystem.ProcessDef[defName="VFEFactory_MakeClusterShells"]</xpath>
						<value>
							<considerBuildingCompResource>true</considerBuildingCompResource>
						</value>
					</match>
				</li>
				<li Class="PatchOperationAddModExtension">
					<xpath>Defs/ThingDef[defName="VCHE_ChemfuelTap"]</xpath>
					<value>
						<li Class="PipeSystem.FactoryHopperExtension">
							<isfactoryHopper>true</isfactoryHopper>
						</li>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>

