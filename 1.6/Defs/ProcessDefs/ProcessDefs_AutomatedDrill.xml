	<PipeSystem.ProcessDef>
		<defName>VFEFactory_DigForSandstoneChunk</defName>
		<label>Dig to harvest a sandstone chunk</label>
		<description>Dig to harvest a sandstone chunk.</description>
		<priorityInBillList>0</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<hideProcessIfNotNaturalRock>true</hideProcessIfNotNaturalRock>
		<rockToDetect>Sandstone</rockToDetect>
		<ticks>14000</ticks>
		<results>
			<li>
				<thing>ChunkSandstone</thing>
				<count>1</count>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedDrillSustainer</sustainerDef>
		<effecterWhenWorking>true</effecterWhenWorking>
		<effecterDef>Drill</effecterDef>
		<worksInSpace>false</worksInSpace>
		<maxOutputCount>3</maxOutputCount>
	</PipeSystem.ProcessDef>
