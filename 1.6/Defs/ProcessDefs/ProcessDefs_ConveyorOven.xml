<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	
	<PipeSystem.ProcessDef>
		<defName>VFEFactory_MakeKibble</defName>
		<label>Make kibble</label>
		<labelOverride>Make kibble</labelOverride>
		<description>Make animal kibble by combining raw meat and plants. 24 kibble will be produced per every nutrition consumed, so 15 vegetable and 15 meat will output 36 kibble.</description>
		<priorityInBillList>0</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<useIngredients>true</useIngredients>
		<autoInputSlots>
			<li>(0,0,3)</li>
			<li>(1,0,3)</li>
			<li>(-1,0,3)</li>
		</autoInputSlots>
		<ticks>1350</ticks>
		<ingredients>
			<li>
				<thingCategory>MeatRaw</thingCategory>
				<countNeeded>15</countNeeded>			
			</li>
			<li>
				<thingCategory>PlantFoodRaw</thingCategory>
				<countNeeded>15</countNeeded>			
			</li>
		</ingredients>
		
		<results>
			<li>
				<thing>Kibble</thing>
				<count>36</count>
				<workerClass>VanillaFurnitureExpandedFactory.ResultWorker_TotalNutrition_Kibble</workerClass>
				<outputStringOverride>VFEFactory_KibbleOutput</outputStringOverride>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedCookingSustainer</sustainerDef>
		<effecterWhenWorking>true</effecterWhenWorking>
		<effecterDef>VFEFactory_Cook</effecterDef>
		<maxOutputCount>75</maxOutputCount>
	</PipeSystem.ProcessDef>
