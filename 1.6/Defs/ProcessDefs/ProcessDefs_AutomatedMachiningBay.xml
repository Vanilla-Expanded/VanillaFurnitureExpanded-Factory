<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	<PipeSystem.ProcessDef>
		<defName>VFEFactory_ShredMechanoid</defName>
		<label>Shred mechanoid</label>
		<labelOverride>Shred mechanoid</labelOverride>
		<description>Use various built-in tools and grinders to shred a mechanoid into steel. 10 steel will be extracted per 1 body size of the mechanoid.</description>
		<priorityInBillList>0</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<autoInputSlots>
			<li>(0,0,3)</li>
			<li>(-3,0,0)</li>
			<li>(3,0,0)</li>
		</autoInputSlots>
		<ticks>1200</ticks>
		<ingredients>
			<li>
				<thingCategory>CorpsesMechanoid</thingCategory>
				<countNeeded>1</countNeeded>
				<ingredientIconOverride>Things/Pawn/Mechanoid/Scyther_east</ingredientIconOverride>
			</li>
		</ingredients>
		
		<results>
			<li>
				<thing>Steel</thing>
				<count>10</count>
				<workerClass>VanillaFurnitureExpandedFactory.ResultWorker_SmeltMechanoid</workerClass>
				<outputStringOverride>VFEFactory_SteelPerBodySize</outputStringOverride>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedMachiningSustainer</sustainerDef>
		<effecterWhenWorking>true</effecterWhenWorking>
		<effecterDef>VFEFactory_Default</effecterDef>
		<maxOutputCount>300</maxOutputCount>
	</PipeSystem.ProcessDef>
</Defs>