<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<PipeSystem.ProcessDef>
		<defName>VFEFactory_AlloyPlasteel</defName>
		<label>Alloy plasteel from steel, chemfuel and gold</label>
		<labelOverride>Alloy plasteel from steel, chemfuel and gold</labelOverride>
		<description>Use high heat and pressure to alloy steel, chemfuel, and gold into pure plasteel.</description>
		<priorityInBillList>0</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<autoInputSlots>
			<li>(-2,0,3)</li>
			<li>(0,0,3)</li>
			<li>(2,0,3)</li>
			
		</autoInputSlots>
		<ticks>20000</ticks>
		<ingredients>
			<li>
				<thing>Steel</thing>
				<countNeeded>10</countNeeded>
			</li>
			<li>
				<thing>Chemfuel</thing>
				<countNeeded>7</countNeeded>
			</li>
			<li>
				<thing>Gold</thing>
				<countNeeded>1</countNeeded>
			</li>
		</ingredients>
		<results>
			<li>
				<thing>Plasteel</thing>
				<count>5</count>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		<effecterWhenWorking>true</effecterWhenWorking>
		<effecterDef>VFEFactory_Smelt</effecterDef>
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedSmeltingSustainer</sustainerDef>
		<maxOutputCount>75</maxOutputCount>
	</PipeSystem.ProcessDef>
