<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<PipeSystem.ProcessDef>
		<defName>VFEFactory_SmeltMetalFromSlag</defName>
		<labelOverride>Smelt 15 steel from slag chunk</labelOverride>
		<label>Smelt 15 steel from slag chunk</label>
		<description>Use heat and strong electromagnets to extract useful metal from slag chunks.</description>
		<priorityInBillList>0</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<autoInputSlots>
			<li>(0,0,3)</li>
			<li>(1,0,3)</li>
			<li>(-1,0,3)</li>
		</autoInputSlots>
		<ticks>1600</ticks>
		<ingredients>
			<li>
				<thing>ChunkSlagSteel</thing>
				<countNeeded>1</countNeeded>
			</li>
		</ingredients>
		<results>
			<li>
				<thing>Steel</thing>
				<count>15</count>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedSmeltingSustainer</sustainerDef>
	</PipeSystem.ProcessDef>
	
	<PipeSystem.ProcessDef>
		<defName>VFEFactory_SmeltWeapon</defName>
		<label>Smelt weapons</label>
		<labelOverride>Smelt weapons</labelOverride>
		<description>Use heat and strong electromagnets to break down weapons into useful resources. This operation will output 25% of the materials used to craft the weapon, excluding any components or advanced components.</description>
		<priorityInBillList>1</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<autoInputSlots>
			<li>(0,0,3)</li>
			<li>(1,0,3)</li>
			<li>(-1,0,3)</li>
		</autoInputSlots>
		<ticks>6400</ticks>
		<ingredients>
			<li>
				<thingCategory>Weapons</thingCategory>
				<countNeeded>1</countNeeded>
				<onlySmeltable>true</onlySmeltable>
				<ingredientIconOverride>Things/Item/Equipment/WeaponRanged/Revolver</ingredientIconOverride>
			</li>
		</ingredients>
		
		<results>
			<li>
				<thing>Steel</thing>
				<count>10</count>
				<workerClass>VanillaFurnitureExpandedFactory.ResultWorker_Smelt</workerClass>
				<outputStringOverride>VFEFactory_VariableOutput</outputStringOverride>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedSmeltingSustainer</sustainerDef>
	</PipeSystem.ProcessDef>
