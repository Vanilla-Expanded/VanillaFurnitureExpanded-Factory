<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<PipeSystem.ProcessDef>
		<defName>VFEFactory_MakeChemfuelFromWood</defName>
		<label>Make chemfuel from wood</label>
		<labelOverride>Make chemfuel from wood</labelOverride>
		<description>Make a batch of chemfuel by extracting and condensing wood gas from logs.</description>
		<priorityInBillList>0</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<autoInputSlots>
			<li>(0,0,3)</li>
			<li>(1,0,3)</li>
			<li>(-1,0,3)</li>
		</autoInputSlots>
		<ticks>5000</ticks>
		<ingredients>
			<li>
				<thing>WoodLog</thing>
				<countNeeded>50</countNeeded>
			</li>
		</ingredients>
		<results>
			<li>
				<thing>Chemfuel</thing>
				<count>25</count>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		<researchPrerequisites>
			<li>BiofuelRefining</li>
		</researchPrerequisites>
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedBrewingSustainer</sustainerDef>
		<effecterWhenWorking>true</effecterWhenWorking>
		<effecterDef>VFEFactory_Cook</effecterDef>
		<maxOutputCount>150</maxOutputCount>
	</PipeSystem.ProcessDef>
	
	<PipeSystem.ProcessDef>
		<defName>VFEFactory_MakeChemfuelFromOrganics</defName>
		<label>Make chemfuel from organics</label>
		<labelOverride>Make chemfuel from organics</labelOverride>
		<description>Make a batch of chemfuel by extracting biofuel from organic feedstocks. Process will consume 30 food items and output 1 chemfuel per each 0.1 nutrition consumed. For example, 30 potatoes will produce 15 chemfuel, while 30 simple meals (0.9 nutrition) will produce 270 chemfuel.</description>
		<priorityInBillList>1</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<autoInputSlots>
			<li>(0,0,3)</li>
			<li>(1,0,3)</li>
			<li>(-1,0,3)</li>
		</autoInputSlots>
		<ticks>4200</ticks>
		<ingredients>
			<li>
				<thingCategory>Foods</thingCategory>
				<countNeeded>30</countNeeded>
				
			</li>
		</ingredients>
		
		<results>
			<li>
				<thing>Chemfuel</thing>
				<count>15</count>
				<workerClass>VanillaFurnitureExpandedFactory.ResultWorker_ScaleOutputByNutrition</workerClass>
				<outputStringOverride>VFEFactory_ChemfuelPerNutrition</outputStringOverride>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		<researchPrerequisites>
			<li>BiofuelRefining</li>
		</researchPrerequisites>
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedBrewingSustainer</sustainerDef>
		<effecterWhenWorking>true</effecterWhenWorking>
		<effecterDef>VFEFactory_Cook</effecterDef>
		<maxOutputCount>150</maxOutputCount>
	</PipeSystem.ProcessDef>
	
