<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<PipeSystem.ProcessDef>
		<defName>VFEFactory_MakeChemfuelFromWood</defName>
		<label>Make 1 chemfuel from 2 wood logs</label>
		<labelOverride>Make 1 chemfuel from 2 wood logs</labelOverride>
		<description>Make a batch of chemfuel by extracting and condensing wood gas from logs.</description>
		<priorityInBillList>0</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<autoInputSlots>
			<li>(0,0,3)</li>
			<li>(1,0,3)</li>
			<li>(-1,0,3)</li>
		</autoInputSlots>
		<ticks>200</ticks>
		<ingredients>
			<li>
				<thing>WoodLog</thing>
				<countNeeded>2</countNeeded>
			</li>
		</ingredients>
		<results>
			<li>
				<thing>Chemfuel</thing>
				<count>1</count>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
	</PipeSystem.ProcessDef>
	
	<PipeSystem.ProcessDef>
		<defName>VFEFactory_MakeChemfuelFromOrganics</defName>
		<label>Make 1 chemfuel for every 0.1 nutrition</label>
		<labelOverride>Make 1 chemfuel for every 0.1 nutrition</labelOverride>
		<description>Make a batch of chemfuel by extracting biofuel from organic feedstocks. Process will consume 2 food items and output 1 chemfuel per each 0.1 nutrition consumed. For example, 2 potatoes will produce 1 chemfuel, while 2 simple meals (0.9 nutrition) will produce 18 chemfuel.</description>
		<priorityInBillList>1</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<autoInputSlots>
			<li>(0,0,3)</li>
			<li>(1,0,3)</li>
			<li>(-1,0,3)</li>
		</autoInputSlots>
		<ticks>280</ticks>
		<ingredients>
			<li>
				<thingCategory>Foods</thingCategory>
				<countNeeded>2</countNeeded>
				
			</li>
		</ingredients>
		
		<results>
			<li>
				<thing>Chemfuel</thing>
				<count>1</count>
				<workerClass>VanillaFurnitureExpandedFactory.ResultWorker_ScaleOutputByNutrition</workerClass>
				<outputStringOverride>VFEFactory_ChemfuelPerNutrition</outputStringOverride>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
	</PipeSystem.ProcessDef>
	
</Defs>