		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<thingCategories>
			<li>VFEFactory_FactoryCategory</li>
		</thingCategories>
		<comps>
			<li Class="CompProperties_Facility">
				<statOffsets>
					<VEF_BuildingMaxOverclockFactor>0.5</VEF_BuildingMaxOverclockFactor>
